{
  "name": "nodejs-devops-pipeline",
  "version": "1.0.0",
  "description": "A simple Node.js application for DevOps pipeline setup",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/server.js",
    "dev": "tsx src/server.ts",
    "test": "jest",
    "db:create": "node dist/db.js createProcessedDataTable",
    "db:drop": "node dist/db.js dropTable"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "make-runnable": "^1.4.1",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
